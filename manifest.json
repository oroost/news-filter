{
  "manifest_version": 3,
  "name": "Word Swapper",
  "version": "1.0.0",
  "description": "Find and replace words on any webpage as you browse.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Word Swapper"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
